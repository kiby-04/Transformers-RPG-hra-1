using namespace std;

struct Item {
    string name;
    string rarity;
    string type;
    int value;
    string desc;
};

struct Character {
    string name;
    int maxHP;
    int hp;
    int damage;
    int abilityUses;
    bool shield;
    string abilityName;
    string abilityDesc;
};

struct Enemy {
    string name;
    int maxHP;
    int hp;
    int damage;
    bool stunned;
};

Item inventory[20];
int invCount = 0;

int coins = 0;
int selectedChar = 0;

Item dropItem() {

    int r = rand()%100;

    if(r<25) return {"Medkit","RARE","heal",70,"vyleci 70 HP"};
    if(r<50) return {"Granat","RARE","damage",85,"85 damage"};
    if(r<70) return {"Fullkit","EPIC","heal",120,"120 HP"};
    if(r<90) return {"Hammer of solus prime","EPIC","damage",120,"120 damage"};

    return {"Starsaber","LEGENDARY","damage",500,"500 damage"};
}

Item shopItem() {

    int r = rand()%100;

    if(r<30) return {"Small Medkit","RARE","heal",60,"vyleci 60 HP"};
    if(r<60) return {"Grenade","RARE","damage",80,"80 damage"};
    if(r<85) return {"Big Heal","EPIC","heal",120,"120 HP"};

    return {"Cyber Blade","LEGENDARY","damage",150,"150 damage"};
}

void intro() {
    cout<<"Deceptikoni napadli Zemi.\n";
    cout<<"Ty jako Autobot musis zastavit invazi.\n\n";
}

void showCharacter(Character p) {

    cout<<"POSTAVA: "<<p.name<<endl;
    cout<<"HP: "<<p.maxHP<<endl;
    cout<<"Damage: "<<p.damage<<endl;
    cout<<"ABILITY: "<<p.abilityName<<endl;
    cout<<"POPIS: "<<p.abilityDesc<<endl;
    cout<<"POUZITI: "<<p.abilityUses<<endl<<endl;
}

void showEnemy(Enemy e) {

    cout<<"NEPRITEL: "<<e.name<<endl;
    cout<<"HP: "<<e.hp<<"/"<<e.maxHP<<endl;
    cout<<"Damage: "<<e.damage<<endl<<endl;
}

bool useItem(Character &p,Enemy &e){

    if(invCount==0){
        cout<<"Inventar je prazdny.\n";
        return false;
    }

    cout<<"INVENTAR:\n";

    for(int i=0;i<invCount;i++)
        cout<<i<<" "<<inventory[i].name<<" - "<<inventory[i].desc<<endl;

    int c;
    cin>>c;

    if(c<0 || c>=invCount){
        cout<<"Spatna volba.\n";
        return false;
    }

    Item it=inventory[c];

    cout<<"Pouzil jsi: "<<it.name<<endl;

    if(it.type=="heal"){
        int before=p.hp;
        p.hp+=it.value;
        if(p.hp>p.maxHP)p.hp=p.maxHP;
        cout<<"Heal +"<<(p.hp-before)<<"\n";
    }

    if(it.type=="damage"){
        e.hp-=it.value;
        cout<<"Enemy dmg -"<<it.value<<"\n";
    }

    for(int i=c;i<invCount-1;i++)
        inventory[i]=inventory[i+1];

    invCount--;

    return true;
}


Enemy miniBoss(int hero){

    if(hero==1) return {"Starscream",300,300,50,false};
    if(hero==2) return {"Soundwave",280,280,40,false};
    return {"Shockblast",320,320,55,false};
}

void village(Character &p){

    while(true){

        cout<<"\n=== VESNICE ===\n";
        cout<<"Coins: "<<coins<<"\n";
        cout<<"HP: "<<p.hp<<"/"<<p.maxHP<<"\n";

        Item shop[3]={shopItem(),shopItem(),shopItem()};

        cout<<"\n=== SHOP (100 coins) ===\n";
        for(int i=0;i<3;i++){
            cout<<i<<") "<<shop[i].name<<" - "<<shop[i].desc<<"\n";
        }

        cout<<"\n1 heal full (60 coins)\n2 buy item\n0 pokracovat\n";

        int c;
        cin>>c;

        if(c==1 && coins>=60){
            p.hp=p.maxHP;
            coins-=60;
            cout<<"HP full\n";
        }

        if(c==2){
            cout<<"Vyber item (0-2): ";
            int x;
            cin>>x;

            if(x>=0 && x<3 && coins>=100){
                inventory[invCount++]=shop[x];
                coins-=100;
                cout<<"Koupen item\n";
            }
        }

        if(c==0){
            cout<<"Leaving village...\n";
            break;
        }
    }
}

