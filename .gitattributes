bool fightMulti(Character &p, Enemy enemies[], int enemyCount){

    cout << "\n=== ENEMIES ===\n";

    while(p.hp > 0){

        bool allDead = true;

        for(int i=0;i<enemyCount;i++){
            if(enemies[i].hp > 0){
                allDead = false;
                break;
            }
        }

        if(allDead) break;

        cout << "\nTVE HP: " << p.hp << "\n";

        for(int i=0;i<enemyCount;i++){
            if(enemies[i].hp > 0){
                cout << i+1 << ") "
                     << enemies[i].name
                     << " HP "
                     << enemies[i].hp
                     << "/"
                     << enemies[i].maxHP
                     << endl;
            }
        }

        cout << "\n1 utok 2 ability 3 inventar\n";

        int c;
        cin >> c;

        int target;

        cout << "Vyber cil: ";
        cin >> target;

        target--;

        if(target < 0 ||
           target >= enemyCount ||
           enemies[target].hp <= 0){
            cout << "Spatny cil\n";
            continue;
        }

        if(c==1){

            enemies[target].hp -= p.damage;

            cout<<"dmg "<<p.damage<<"\n";
        }

        if(c==2){

            if(p.abilityUses<=0){
                cout<<"No ability\n";
                continue;
            }

            if(p.name=="Optimus Prime"){
                p.hp+=100;
                if(p.hp>p.maxHP)p.hp=p.maxHP;
                cout<<"Matrix of leader ship\n";
            }

            if(p.name=="Bumblebee"){
                enemies[target].hp-=200;
                cout<<"laser shot\n";
            }

            if(p.name=="Ironhide"){
                enemies[target].hp-=100;
                cout<<"iron fist\n";
            }

            p.abilityUses--;
        }

        if(c==3){

            if(invCount==0){
                cout<<"Inventar je prazdny.\n";
                continue;
            }

            cout<<"INVENTAR:\n";

            for(int i=0;i<invCount;i++)
                cout<<i<<" "<<inventory[i].name<<" - "<<inventory[i].desc<<endl;

            int itemChoice;
            cin>>itemChoice;

            if(itemChoice<0 || itemChoice>=invCount){
                cout<<"Spatna volba.\n";
                continue;
            }

            Item it=inventory[itemChoice];

            if(it.type=="heal"){
                p.hp+=it.value;
                if(p.hp>p.maxHP)p.hp=p.maxHP;
            }

            if(it.type=="damage"){
                enemies[target].hp-=it.value;
            }

            for(int i=itemChoice;i<invCount-1;i++)
                inventory[i]=inventory[i+1];

            invCount--;
        }

        for(int i=0;i<enemyCount;i++){

            if(enemies[i].hp>0){

                cout<<enemies[i].name
                    <<" utoci za "
                    <<enemies[i].damage
                    <<endl;

                p.hp-=enemies[i].damage;
            }
        }
    }

    if(p.hp<=0)
        return false;

    for(int i=0;i<enemyCount;i++){

        Item drop=dropItem();

        inventory[invCount++]=drop;

        int reward = 10 + rand()%100;

        coins += reward;

        cout<<"\nZISK: "
            <<drop.name
            <<" + "
            <<reward
            <<" coins\n";
    }

    return true;
}

